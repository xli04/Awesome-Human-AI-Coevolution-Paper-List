---
import Base from '../layouts/Base.astro';
import { loadAllPapers } from '../lib/parsePapers';
import { ENV_ORDER, ENV_ABBREV, PHASE_ORDER, PHASE_CODE, PHASE_HEADINGS, REPO_URL } from '../lib/site';
import { getStarCount } from '../lib/star';

const { canonical } = loadAllPapers();
const envCount: Record<string, number> = {};
for (const p of canonical) for (const e of p.envs) envCount[e] = (envCount[e] ?? 0) + 1;

const phaseCount: Record<string, number> = {};
for (const p of canonical) {
  const tag = p.phase ?? 'framework';
  phaseCount[tag] = (phaseCount[tag] ?? 0) + 1;
}

const lastYear = new Date().getFullYear();
// "Last entry" should display the most recent paper's human-readable
// date — not the internal ISO anchor. parsePapers sorts newest-first
// and anchors year-only dates to YYYY-12-31 for stable ordering, but
// that anchored value is misleading in a date field on the masthead.
// Using paper.date (the display string) gives "April 06, 2026" for
// day-precision, "April 2026" for month-only, "2026" for year-only.
const lastUpdated = canonical[0]?.date ?? '';
const stars = await getStarCount();

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = (Astro.site ?? new URL('https://xli04.github.io')).toString().replace(/\/$/, '') + base;

const description = `An index of ${canonical.length}+ research papers on human–AI coevolution, organized by the four-phase framework — Tool, Assistant, Executor, Organization.`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Human–AI Coevolution Index',
    url: siteUrl + '/',
    description,
    inLanguage: 'en',
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: `${siteUrl}/papers/?q={search_term_string}` },
      'query-input': 'required name=search_term_string',
    },
  },
];
---
<Base title="An index of human–AI coevolution research" description={description} jsonLd={jsonLd}>

  <header class="mx-auto max-w-[1180px] px-6 pt-16 pb-12 reveal-stagger">
    <div class="grid lg:grid-cols-[200px_minmax(0,1fr)] gap-x-16 gap-y-8">

      <aside class="lg:border-r border-paper-300 dark:border-ink-600 lg:pr-6">
        <p class="meta-label">Index № 01</p>
        <p class="kicker mt-2 text-ink-700 dark:text-ink-50">v1 · {lastYear}</p>

        <dl class="mt-8 space-y-3 text-[12.5px]">
          <div>
            <dt class="meta-label">Entries</dt>
            <dd class="meta-value mt-0.5 tabular-nums">{canonical.length}</dd>
          </div>
          <div>
            <dt class="meta-label">Phases</dt>
            <dd class="meta-value mt-0.5 tabular-nums">4 + 3 emerging</dd>
          </div>
          <div>
            <dt class="meta-label">Last entry</dt>
            <dd class="meta-value mt-0.5">{lastUpdated || '—'}</dd>
          </div>
        </dl>

        <div class="mt-8 space-y-2 text-[12.5px]">
          <a href={REPO_URL} target="_blank" rel="noopener" class="action-link action-link--ghost">
            <span class="font-mono">↗</span>{stars != null ? `Star · ${stars}` : 'GitHub'}
          </a>
          <div>
            <a href={`${REPO_URL}/blob/main/papers.yaml`} target="_blank" rel="noopener" class="action-link action-link--ghost">
              <span class="font-mono">↓</span>papers.yaml
            </a>
          </div>
        </div>
      </aside>

      <div>
        <p class="heading-eyebrow">Human–AI Coevolution Index</p>

        <h1 class="kicker-xl mt-6 text-ink-700 dark:text-ink-50 max-w-[22ch]">
          An index of research on how <em class="text-accent dark:text-accent-dark italic">humans must evolve</em> as AI evolves.
        </h1>

        <div class="mt-8 text-[16.5px] text-ink-600 dark:text-ink-200 leading-[1.7] max-w-[60ch] space-y-5">
          <p>
            Grounded in a <strong class="text-ink-700 dark:text-ink-50">four-phase framework</strong> — Tool · Assistant · Executor · Organization — for how humans use AI in their work. As AI takes on more, humans must develop the matching capability to use it well: critical thinking, evaluative expertise, metacognitive monitoring, and systems thinking.
          </p>
          <p>
            Each entry is grounded evidence for one phase. The list documents how human capabilities are <em class="italic">empowered</em> and <em class="italic">weakened</em> by AI advancement, and what humans and AI systems can do to co-evolve well.
          </p>
        </div>

        <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-3">
          <a href={`${base}/papers`} class="action-link action-link--primary">Browse the index <span class="font-mono">→</span></a>
          <a href={`${base}/stats`} class="action-link action-link--ghost">Statistics <span class="font-mono">→</span></a>
          <a href={`${base}/about`} class="action-link action-link--ghost">About <span class="font-mono">→</span></a>
        </div>
      </div>
    </div>
  </header>

  {/* ─── Primary axis: by phase ──────────────────────────────────── */}
  <section class="mx-auto max-w-[1180px] px-6 mt-20 reveal">
    <div class="grid lg:grid-cols-[200px_minmax(0,1fr)] gap-x-16">
      <div class="lg:border-r border-paper-300 dark:border-ink-600 lg:pr-6">
        <p class="meta-label">Contents</p>
        <p class="mt-3 text-[13px] text-ink-500 dark:text-ink-300 leading-relaxed max-w-[14em]">
          Eight tags: four phases, three bridge phases, and a framework bucket for cross-cutting work.
        </p>
      </div>

      <ol class="list-none p-0 max-w-[64ch]">
        {PHASE_ORDER.map((tag) => {
          const h = PHASE_HEADINGS[tag];
          const n = phaseCount[tag] ?? 0;
          // Phase 4 stays visible at 0 so the "no domain has fully entered"
          // framing is on the page. Other empty buckets are hidden.
          if (n === 0 && tag !== 'phase-4') return null;
          const isEmpty = n === 0;
          const rowClass = isEmpty
            ? 'grid grid-cols-[72px_1fr_auto] gap-x-5 items-baseline py-7 border-t border-paper-300 dark:border-ink-600 opacity-70'
            : 'grid grid-cols-[72px_1fr_auto] gap-x-5 items-baseline py-7 border-t border-paper-300 dark:border-ink-600 group hover:bg-paper-200/40 dark:hover:bg-ink-700/20 transition-colors';
          const inner = (
            <>
              <span class="phase-badge-xl tabular-nums">{PHASE_CODE[tag]}</span>
              <div>
                <div class={isEmpty
                  ? 'kicker text-ink-500 dark:text-ink-300'
                  : 'kicker text-ink-700 dark:text-ink-50 group-hover:text-accent dark:group-hover:text-accent-dark transition-colors'}>
                  {h.title}
                </div>
                <p class="mt-1 text-[12px] font-mono uppercase tracking-[0.06em] text-ink-400 dark:text-ink-300">
                  {h.role} <span class="text-paper-400 dark:text-ink-600">·</span> Capability: <span class="text-ink-500 dark:text-ink-200 normal-case tracking-normal">{h.capability}</span>
                </p>
                <p class="mt-2 text-[13.5px] text-ink-500 dark:text-ink-300 max-w-[52ch] leading-relaxed">{h.blurb}</p>
              </div>
              <span class="meta-label tabular-nums">{isEmpty ? '—' : n}</span>
            </>
          );
          return (
            <li>
              {isEmpty ? (
                <div class={rowClass}>{inner}</div>
              ) : (
                <a href={`${base}/papers?phase=${encodeURIComponent(tag)}`} class={rowClass}>{inner}</a>
              )}
            </li>
          );
        })}
        <li><div class="border-t border-paper-300 dark:border-ink-600"></div></li>
      </ol>
    </div>
  </section>

  {/* ─── Secondary axis: 5 paper themes ──────────────────────────── */}
  <section class="mx-auto max-w-[1180px] px-6 mt-20 reveal">
    <div class="grid lg:grid-cols-[200px_minmax(0,1fr)] gap-x-16">
      <div class="lg:border-r border-paper-300 dark:border-ink-600 lg:pr-6">
        <p class="meta-label">Secondary axis</p>
        <p class="mt-3 text-[13px] text-ink-500 dark:text-ink-300 leading-relaxed max-w-[14em]">
          Cross-cuts the phase axis with five thematic tags. A paper may have one or more.
        </p>
      </div>

      <ol class="list-none p-0 max-w-[60ch]">
        {ENV_ORDER.map((env) => (
          <li>
            <a
              href={`${base}/papers?env=${encodeURIComponent(env)}`}
              class="grid grid-cols-[48px_1fr_auto] gap-x-5 items-baseline py-4 border-t border-paper-300 dark:border-ink-600 group hover:bg-paper-200/40 dark:hover:bg-ink-700/20 transition-colors"
            >
              <span class="meta-value tabular-nums text-accent dark:text-accent-dark">{ENV_ABBREV[env]}</span>
              <div class="font-display text-[16px] text-ink-700 dark:text-ink-50 group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">{env}</div>
              <span class="meta-label tabular-nums">{envCount[env] ?? 0}</span>
            </a>
          </li>
        ))}
        <li><div class="border-t border-paper-300 dark:border-ink-600"></div></li>
      </ol>
    </div>
  </section>

  {/* ─── Colophon ──────────────────────────────────────────────── */}
  <section class="mx-auto max-w-[1180px] px-6 mt-24 pb-20">
    <div class="grid lg:grid-cols-[200px_minmax(0,1fr)] gap-x-16">
      <div class="lg:border-r border-paper-300 dark:border-ink-600 lg:pr-6">
        <p class="meta-label">Colophon</p>
      </div>
      <p class="text-[14.5px] text-ink-600 dark:text-ink-200 leading-relaxed max-w-[60ch]">
        Curated and openly maintained on GitHub. The website is generated from a single YAML source; suggest an entry by opening an issue or PR.
      </p>
    </div>
  </section>
</Base>
