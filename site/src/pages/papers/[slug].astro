---
import Base from '../../layouts/Base.astro';
import { loadAllPapers, type Paper } from '../../lib/parsePapers';
import { ENV_EMOJI, REPO_URL } from '../../lib/site';
import { normalizePublisher, bibtexVenueKind } from '../../lib/venues';

interface RelatedLite {
  slug: string;
  title: string;
  date: string;
  publisher: string;
}

export async function getStaticPaths() {
  const { canonical, adjacent } = loadAllPapers();
  const all = [...canonical, ...adjacent];

  // Pre-compute related papers per paper at build time, keep slim.
  const related = new Map<string, RelatedLite[]>();
  for (const target of all) {
    const kwSet = new Set(target.keywords);
    const envSet = new Set(target.envs);
    const scored = canonical
      .filter((p) => p.slug !== target.slug)
      .map((p) => {
        let kw = 0;
        for (const k of p.keywords) if (kwSet.has(k)) kw++;
        let env = 0;
        for (const e of p.envs) if (envSet.has(e)) env++;
        return { p, score: kw * 2 + env };
      })
      .filter((x) => x.score >= 2)
      .sort((a, b) => b.score - a.score || (a.p.dateISO < b.p.dateISO ? 1 : -1))
      .slice(0, 6)
      .map((x) => ({
        slug: x.p.slug, title: x.p.title, date: x.p.date, publisher: x.p.publisher,
      }));
    related.set(target.slug, scored);
  }

  return all.map((p) => ({
    params: { slug: p.slug },
    props: { paper: p, related: related.get(p.slug) ?? [] },
  }));
}

const { paper, related } = Astro.props as { paper: Paper; related: RelatedLite[] };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteOrigin = (Astro.site ?? new URL('https://xli04.github.io')).toString().replace(/\/$/, '');
const detailUrl = `${siteOrigin}${base}/papers/${paper.slug}/`;

const tldrFallback = `${paper.title} — ${paper.publisher}, ${paper.date}. Authors: ${paper.authors.slice(0, 5).join(', ')}${paper.authors.length > 5 ? ', et al.' : ''}.`;
const seoDescription = (paper.tldr || tldrFallback).slice(0, 300);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ScholarlyArticle',
    headline: paper.title,
    name: paper.title,
    abstract: paper.tldr || undefined,
    url: detailUrl,
    sameAs: [paper.link, ...(paper.arxivId ? [`https://arxiv.org/abs/${paper.arxivId}`] : [])],
    datePublished: paper.dateISO,
    inLanguage: 'en',
    author: paper.authors.map((name) => ({ '@type': 'Person', name })),
    publisher: paper.publisher
      ? { '@type': 'Organization', name: paper.publisher }
      : undefined,
    keywords: [...paper.envs, ...paper.keywords].join(', ') || undefined,
    isPartOf: {
      '@type': 'DataCatalog',
      name: 'Human-AI Coevolution Paper List',
      url: `${siteOrigin}${base}/`,
    },
    mainEntityOfPage: detailUrl,
    identifier: paper.arxivId ? `arXiv:${paper.arxivId}` : undefined,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Human-AI Coevolution Papers', item: `${siteOrigin}${base}/` },
      { '@type': 'ListItem', position: 2, name: 'Browse', item: `${siteOrigin}${base}/papers/` },
      { '@type': 'ListItem', position: 3, name: paper.title, item: detailUrl },
    ],
  },
];

function bibKey(p: Paper): string {
  const lastName = (p.authors[0] ?? 'unknown').split(/\s+/).pop()!.toLowerCase().replace(/[^a-z]/g, '') || 'anon';
  const titleWord = p.title.split(/\s+/).find((w) => w.length > 3)?.toLowerCase().replace(/[^a-z0-9]/g, '') ?? 'paper';
  const year = p.year > 0 ? p.year : '';
  return `${lastName}${year}${titleWord}`;
}
function escBib(s: string): string {
  return s.replace(/\\/g, '\\textbackslash ').replace(/([&%$#_{}])/g, '\\$1').replace(/~/g, '\\~{}').replace(/\^/g, '\\^{}');
}
function buildBib(p: Paper): string {
  // Prefer the entry's stored bibtex (auto-generated migration output,
  // optionally hand-corrected with bibtex_confirmed: true).
  if (p.bibtex && p.bibtex.trim()) return p.bibtex;
  return synthesizeBib(p);
}

function synthesizeBib(p: Paper): string {
  const key = bibKey(p);
  const authors = p.authors.length > 0 ? p.authors.map(escBib).join(' and ') : 'Unknown';
  const titleEsc = escBib(p.title);
  const year = p.year > 0 ? String(p.year) : '';
  const venue = normalizePublisher(p.publisher);
  const kindLabel = bibtexVenueKind(p.publisher);

  const f: Array<[string, string]> = [];
  f.push(['title', `{${titleEsc}}`]);
  f.push(['author', `{${authors}}`]);
  if (year) f.push(['year', `{${year}}`]);
  let kind = '@inproceedings';
  if (kindLabel === 'misc' && p.arxivId) {
    kind = '@misc';
    f.push(['eprint', `{${p.arxivId}}`]);
    f.push(['archivePrefix', `{arXiv}`]);
    f.push(['url', `{https://arxiv.org/abs/${p.arxivId}}`]);
  } else if (kindLabel === 'misc') {
    kind = '@misc';
    f.push(['howpublished', `{${escBib(p.publisher || 'Preprint')}}`]);
    f.push(['url', `{${p.link}}`]);
  } else if (kindLabel === 'article') {
    kind = '@article';
    f.push(['journal', `{${escBib(venue)}}`]);
    if (p.arxivId) f.push(['eprint', `{${p.arxivId}}`]);
    f.push(['url', `{${p.link}}`]);
  } else {
    f.push(['booktitle', `{${escBib(venue)}}`]);
    if (p.arxivId) {
      f.push(['eprint', `{${p.arxivId}}`]);
      f.push(['archivePrefix', `{arXiv}`]);
    }
    f.push(['url', `{${p.link}}`]);
  }
  const indented = f.map(([k, v]) => `  ${k} = ${v}`).join(',\n');
  return `${kind}{${key},\n${indented}\n}`;
}
const bibtex = buildBib(paper);

const issueBody = [
  `**Paper title:** ${paper.title}`,
  `**Paper link:** ${paper.link}`,
  `**Source line:** ${paper.source === 'adjacent' ? 'adjacent.yaml' : 'papers.yaml'}#L${paper.sourceLine}`,
  '',
  '### What is incorrect or missing?',
  '<!-- Please describe the issue (e.g., wrong authors, wrong date, wrong publisher, missing keyword, broken link). -->',
  '',
].join('\n');

const reportUrl = `${REPO_URL}/issues/new?` + new URLSearchParams({
  title: `[Metadata] ${paper.title}`,
  body: issueBody,
  labels: 'metadata-correction',
  template: 'metadata-correction.yml',
}).toString();
---
<Base
  title={paper.title}
  description={seoDescription}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-reading px-4 sm:px-6 py-10" itemscope itemtype="https://schema.org/ScholarlyArticle">
    <nav class="text-xs text-ink-400 dark:text-ink-300" aria-label="Breadcrumb">
      <a class="link" href={`${base}/papers`}>← Browse all papers</a>
    </nav>

    <h1 class="display-lg mt-4 text-ink-700 dark:text-ink-50 leading-[1.08]" itemprop="headline">
      <a href={paper.link} target="_blank" rel="noopener" class="hover:text-accent dark:hover:text-accent-dark">{paper.title}</a>
    </h1>

    <p class="mt-4 text-ink-500 dark:text-ink-200 leading-relaxed">{paper.authors.join(', ')}</p>

    <dl class="mt-6 grid grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm">
      <dt class="text-ink-400 dark:text-ink-300">🏛 Institutions</dt>
      <dd class="text-ink-600 dark:text-ink-100">{paper.institutions.join(', ') || '—'}</dd>

      <dt class="text-ink-400 dark:text-ink-300">📅 Date</dt>
      <dd class="text-ink-600 dark:text-ink-100">{paper.date}</dd>

      <dt class="text-ink-400 dark:text-ink-300">📑 Publisher</dt>
      <dd class="text-ink-600 dark:text-ink-100">{paper.publisher}</dd>

      <dt class="text-ink-400 dark:text-ink-300">💻 Env</dt>
      <dd class="text-ink-600 dark:text-ink-100 flex flex-wrap gap-3">
        {paper.envs.map((env) => (
          <span class="inline-flex items-center gap-1.5">
            <span aria-hidden="true">{ENV_EMOJI[env] ?? '🖼️'}</span>
            <a class="link" href={`${base}/papers?env=${encodeURIComponent(env)}`}>{env}</a>
          </span>
        ))}
      </dd>

      <dt class="text-ink-400 dark:text-ink-300">🔑 Keywords</dt>
      <dd>
        <div class="flex flex-wrap gap-1.5">
          {paper.keywords.map((kw) => (
            <a class="chip" href={`${base}/papers?key=${encodeURIComponent(kw)}`}>{kw}</a>
          ))}
        </div>
      </dd>
    </dl>

    {paper.tldr && (
      <section class="mt-8">
        <div class="heading-eyebrow mb-2">TLDR</div>
        <p class="text-base leading-relaxed text-ink-700 dark:text-ink-50">{paper.tldr}</p>
      </section>
    )}

    <section class="mt-8 flex flex-wrap items-center gap-3">
      <a href={paper.link} target="_blank" rel="noopener" class="btn-primary">
        <span>Open paper</span><span aria-hidden="true">↗</span>
      </a>
      {paper.arxivId && (
        <a href={`https://arxiv.org/abs/${paper.arxivId}`} target="_blank" rel="noopener" class="btn-ghost border border-paper-300/80 dark:border-ink-600/60">arXiv</a>
      )}
      <button
        type="button"
        id="copy-bib-btn"
        data-bib={bibtex}
        class="btn-ghost border border-paper-300/80 dark:border-ink-600/60 inline-flex items-center gap-1.5"
        aria-label="Copy BibTeX to clipboard"
      >
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <span id="copy-bib-label">Copy BibTeX</span>
      </button>
      <a href={reportUrl} target="_blank" rel="noopener" class="btn-ghost border border-paper-300/80 dark:border-ink-600/60">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
        Report issue
      </a>
    </section>

    <script is:inline>
      (function () {
        var btn = document.getElementById('copy-bib-btn');
        var label = document.getElementById('copy-bib-label');
        if (!btn || !label) return;
        btn.addEventListener('click', function () {
          var bib = btn.getAttribute('data-bib') || '';
          var done = function () {
            label.textContent = 'BibTeX copied';
            setTimeout(function () { label.textContent = 'Copy BibTeX'; }, 1600);
          };
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(bib).then(done).catch(function () {
              // fallback
              var ta = document.createElement('textarea');
              ta.value = bib; document.body.appendChild(ta); ta.select();
              try { document.execCommand('copy'); done(); } finally { ta.remove(); }
            });
          } else {
            var ta = document.createElement('textarea');
            ta.value = bib; document.body.appendChild(ta); ta.select();
            try { document.execCommand('copy'); done(); } finally { ta.remove(); }
          }
        });
      })();
    </script>

    {related.length > 0 && (
      <section class="mt-12">
        <div class="heading-eyebrow mb-3">Related papers</div>
        <ul class="grid sm:grid-cols-2 gap-3">
          {related.map((p) => (
            <li>
              <a href={`${base}/papers/${p.slug}`} class="block card p-4 hover:border-accent/60 dark:hover:border-accent-dark/60">
                <div class="text-sm font-medium text-ink-700 dark:text-ink-50 line-clamp-2">{p.title}</div>
                <div class="mt-1 text-xs text-ink-400 dark:text-ink-300">{p.date} · {p.publisher}</div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Base>
