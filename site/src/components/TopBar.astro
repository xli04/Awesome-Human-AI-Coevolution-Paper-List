---
import ThemeToggle from './ThemeToggle.astro';
import { REPO_URL, SITE_TITLE } from '../lib/site';
const { starCount } = Astro.props as { starCount: number | null };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function fmt(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(n >= 10000 ? 0 : 1).replace(/\.0$/, '') + 'k';
  return String(n);
}

const navItems = [
  { href: `${base}/papers`,   label: 'Index' },
  { href: `${base}/stats`,    label: 'Stats' },
  { href: `${base}/adjacent`, label: 'Adjacent' },
  { href: `${base}/about`,    label: 'Colophon' },
];
const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

{/* Static masthead — not sticky. A thin top rule + brand on left + tiny
    text-link nav on right. No buttons, no logo badge, no chip-style nav. */}
<div class="border-b border-paper-300 dark:border-ink-600 bg-paper-100 dark:bg-nightbg">
  <div class="mx-auto max-w-[1180px] px-6 h-12 flex items-center gap-6">
    <a href={`${base}/`} class="flex items-baseline gap-3 group">
      <span class="font-display text-[15px] font-medium tracking-tight text-ink-700 dark:text-ink-50 group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">{SITE_TITLE}</span>
    </a>

    <nav class="hidden md:flex items-baseline gap-5 ml-auto">
      {navItems.map((item) => {
        const active = currentPath === item.href.replace(/\/$/, '') ||
          (item.href !== `${base}/` && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`font-mono text-[11px] uppercase tracking-[0.12em] transition-colors ${
              active
                ? 'text-accent dark:text-accent-dark underline underline-offset-[5px] decoration-accent dark:decoration-accent-dark'
                : 'text-ink-500 dark:text-ink-300 hover:text-ink-700 dark:hover:text-ink-50'
            }`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="md:hidden ml-auto"></div>

    <a
      href={REPO_URL}
      target="_blank"
      rel="noopener"
      class="hidden sm:inline-flex items-baseline gap-1.5 font-mono text-[11px] uppercase tracking-[0.12em] text-ink-500 dark:text-ink-300 hover:text-ink-700 dark:hover:text-ink-50 transition-colors"
      aria-label="View on GitHub"
    >
      <span>GitHub</span><span class="font-mono">↗</span>{starCount != null && <span class="tabular-nums">· {fmt(starCount)}</span>}
    </a>

    <ThemeToggle />
  </div>
</div>
